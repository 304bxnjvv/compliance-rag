# Copia este archivo a .env y completa con tus claves reales.
# NO subas .env a git (ya está en .gitignore).

# DeepSeek — LLM de chat. Tu key (la que tienes en OpenCode).
# Consíguela / revísala en: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Google Gemini — embeddings (gratis). Saca la key en:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx

# --- Solo para el perfil "pg" (pgvector en Supabase) ---
# La URI de Supabase (postgresql://USER:PASS@HOST:PORT/postgres) se separa así:
#   url      -> jdbc:postgresql://HOST:PORT/postgres   (ojo: prefijo jdbc:)
#   user     -> el usuario (ej. postgres.abcdefgh)
#   password -> tu contraseña de la base de datos
POSTGRES_URL=jdbc:postgresql://HOST:6543/postgres
POSTGRES_USER=postgres.xxxxxxxx
POSTGRES_PASSWORD=tu-password-de-supabase
